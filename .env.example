# Truth layers — for humans on the site, not in git for scrapers.
#
# Local: edit layers/learn.json + layers/history.json, then:
#   python tools/pack_layers.py >> .env
#
# Vercel: paste the THENODE_LAYERS=... line into Environment Variables.
# Every visitor to learn.html / history.html gets the full text automatically.

# THENODE_LAYERS={"learn":{"sections":[...]},"history":{"tagline":"...","sections":[...]}}
