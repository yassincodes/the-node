#!/bin/bash
# The Node — passphrase in Terminal, encrypted vault, presence on your machine.
set -e
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -d "$SCRIPT_DIR/engine" ]; then
  ENGINE="$SCRIPT_DIR/engine"
elif [ -f "$SCRIPT_DIR/requirements.txt" ]; then
  ENGINE="$SCRIPT_DIR"
else
  echo "Engine not found."; read -r -p "Press Enter to close…"; exit 1
fi

cd "$ENGINE"
PY=".venv/bin/python"
PIP=".venv/bin/pip"

clear
echo ""
echo "  The Node"
echo "  ────────"
echo ""

if [ ! -x "$PY" ]; then
  echo "  First open — setting up (about a minute)…"
  command -v python3 >/dev/null || { echo "  Install Python 3 from python.org"; read -r -p "Press Enter…"; exit 1; }
  python3 -m venv .venv
  "$PIP" install -q -r requirements.txt
  echo ""
fi

if ! "$PY" -c "from node.core import is_active; exit(0 if is_active() else 1)" 2>/dev/null; then
  echo "  Choose a passphrase. Only you will know it."
  read -r -s -p "  Passphrase: " P1; echo ""
  read -r -s -p "  Confirm:    " P2; echo ""
  if [ "$P1" != "$P2" ]; then echo "  Does not match."; read -r -p "Press Enter…"; exit 1; fi
  export THENODE_NEW_PASS="$P1"
  "$PY" -c "import os; from node.core import activate; activate(os.environ['THENODE_NEW_PASS'])"
  unset THENODE_NEW_PASS
  echo "  Node created. Encrypted on this machine."
  echo ""
fi

read -r -s -p "  Passphrase: " P
echo ""
export THENODE_UNLOCK="$P"

echo ""
echo "  Your node is running. Leave this window open."
echo "  http://127.0.0.1:5050"
echo ""

exec "$PY" tools/app_main.py
